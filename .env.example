# ===== App =====
APP_NAME=AI Agent Core
DEBUG=True
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000

# ===== Startup =====
# lenient: 필수 설정 없어도 기동 | strict: 저장소+LLM API 키 없으면 기동 불가
STARTUP_MODE=lenient

# ===== Database (설치형 / Docker) =====
# docker-compose 사용 시 자동 주입. 로컬 Postgres 예:
# DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agent_core
DATABASE_URL=
# API 키 DB 저장용 Fernet 키 — python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# ===== Webhook =====
WEBHOOK_SECRET=

# ===== Repository Provider =====
REPOSITORY_PROVIDER=gitlab

# GitLab (REPOSITORY_PROVIDER=gitlab)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=

# GitHub (REPOSITORY_PROVIDER=github)
# GITHUB_BASE_URL=https://api.github.com
# GITHUB_ACCESS_TOKEN=
# GITHUB_DEFAULT_REPO=owner/repo

# ===== LLM Provider =====
# gemini | openai | anthropic | local — primary 공급자 (API 키·model id 직접 입력)
DEFAULT_LLM_PROVIDER=gemini
# primary 실패 시 순서대로 시도 (쉼표 구분, 설정된 공급자만 사용)
LLM_FALLBACK_PROVIDERS=

# Gemini model id: https://ai.google.dev/gemini-api/docs/models
GEMINI_API_KEY=
GEMINI_MODEL=

# OpenAI model id: https://platform.openai.com/docs/models
# OPENAI_API_KEY=
# OPENAI_MODEL=

# Anthropic (Claude) model id: https://docs.anthropic.com/en/docs/about-claude/models/overview
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=

# Local LLM (Ollama/vLLM/LM Studio — OpenAI 호환 API)
# DEFAULT_LLM_PROVIDER=local
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=qwen3.5
# LOCAL_LLM_API_KEY=

# ===== Plugins =====
PLUGINS_DIR=services/plugins

# 가이드: docs/setup/repository_provider_guide.md
#       docs/setup/llm_provider_guide.md

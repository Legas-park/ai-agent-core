# 회사 GitLab 연동용 .env 템플릿 (E1-b)
# GitHub 개인 검증 후 cp .env.gitlab.company.example .env 로 복사해 사용

# ===== App =====
APP_NAME=AI Agent Core
DEBUG=False
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000

# ===== Startup =====
STARTUP_MODE=strict

# ===== Webhook =====
WEBHOOK_SECRET=

# ===== Repository (GitLab) =====
REPOSITORY_PROVIDER=gitlab
GITLAB_URL=https://gitlab.com
# Self-hosted: https://gitlab.your-company.com
GITLAB_TOKEN=
# 선택: 단일 프로젝트
# GITLAB_DEFAULT_PROJECT_ID=

# ===== LLM =====
DEFAULT_LLM_PROVIDER=gemini
LLM_FALLBACK_PROVIDERS=

GEMINI_API_KEY=
GEMINI_MODEL=

# ===== Plugins =====
PLUGINS_DIR=services/plugins

# 가이드: docs/migration/company-deploy.md

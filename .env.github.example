# GitHub 개인 연동용 .env 템플릿 (E1)
# 사용: cp .env.github.example .env 후 아래 값을 채우세요. .env 는 git에 커밋하지 마세요.

# ===== App =====
APP_NAME=AI Agent Core
DEBUG=True
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000

# ===== Startup =====
STARTUP_MODE=strict

# ===== Webhook =====
# GitHub Webhook Secret 과 동일한 값 (임의의 긴 문자열)
WEBHOOK_SECRET=change-me-to-a-long-random-string

# ===== Repository (GitHub) =====
REPOSITORY_PROVIDER=github
GITHUB_BASE_URL=https://api.github.com
GITHUB_ACCESS_TOKEN=
# 선택: 단일 repo 고정 시
GITHUB_DEFAULT_REPO=Legas-park/ai-agent-core

# ===== LLM (primary 1개 필수) =====
DEFAULT_LLM_PROVIDER=gemini
LLM_FALLBACK_PROVIDERS=

GEMINI_API_KEY=
GEMINI_MODEL=

# Anthropic 예시
# DEFAULT_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=

# ===== Plugins =====
PLUGINS_DIR=services/plugins

# 가이드: docs/setup/github-personal-e2e.md

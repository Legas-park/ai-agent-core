# ===== App =====
APP_NAME=AI Agent Core
DEBUG=True
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000

# ===== Startup =====
# lenient: 필수 설정 없어도 기동 | strict: 저장소+LLM API 키 없으면 기동 불가
STARTUP_MODE=lenient

# ===== Webhook =====
WEBHOOK_SECRET=

# ===== Repository Provider =====
REPOSITORY_PROVIDER=gitlab

# GitLab (REPOSITORY_PROVIDER=gitlab)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=

# GitHub (REPOSITORY_PROVIDER=github)
# GITHUB_BASE_URL=https://api.github.com
# GITHUB_ACCESS_TOKEN=
# GITHUB_DEFAULT_REPO=owner/repo

# ===== LLM Provider =====
# gemini | openai — 선택한 공급자의 API 키가 필요합니다 (strict 모드)
DEFAULT_LLM_PROVIDER=gemini

# Gemini 모델: gemini-2.0-flash | gemini-2.0-flash-lite | gemini-1.5-flash | gemini-1.5-flash-8b | gemini-1.5-pro
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI 모델: gpt-4o | gpt-4o-mini | gpt-4-turbo | o1-mini | o3-mini
# DEFAULT_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ===== Plugins =====
PLUGINS_DIR=services/plugins

# 가이드: docs/setup/repository_provider_guide.md
#       docs/setup/llm_provider_guide.md

# ===== App =====
APP_NAME=AI Agent Core
DEBUG=True
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000

# ===== Startup =====
# lenient: 필수 설정 없어도 기동 | strict: 저장소+LLM API 키 없으면 기동 불가
STARTUP_MODE=lenient

# ===== Webhook =====
WEBHOOK_SECRET=

# ===== Repository Provider =====
REPOSITORY_PROVIDER=gitlab

# GitLab (REPOSITORY_PROVIDER=gitlab)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=

# GitHub (REPOSITORY_PROVIDER=github)
# GITHUB_BASE_URL=https://api.github.com
# GITHUB_ACCESS_TOKEN=
# GITHUB_DEFAULT_REPO=owner/repo

# ===== LLM Provider =====
# gemini | openai — 선택한 공급자의 API 키·model id를 직접 입력 (strict 모드)
DEFAULT_LLM_PROVIDER=gemini

# Gemini model id: https://ai.google.dev/gemini-api/docs/models
GEMINI_API_KEY=
GEMINI_MODEL=

# OpenAI model id: https://platform.openai.com/docs/models
# DEFAULT_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=

# ===== Plugins =====
PLUGINS_DIR=services/plugins

# 가이드: docs/setup/repository_provider_guide.md
#       docs/setup/llm_provider_guide.md
